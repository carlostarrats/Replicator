{
  "name": "bulk secret migration",
  "command": "secrets-migrate",
  "sourceProject": "vcopy-test-source",
  "targetProject": "vcopy-test-target",
  "destructive": true,
  "allowedProjectPrefix": "vcopy-test-",
  "dryRunCommand": [
    "secrets-migrate",
    "--from",
    "vcopy-test-source",
    "--to",
    "vcopy-test-target",
    "--keys",
    "DATABASE_URL,OPENAI_API_KEY",
    "--dry-run"
  ],
  "applyCommand": [
    "secrets-migrate",
    "--from",
    "vcopy-test-source",
    "--to",
    "vcopy-test-target",
    "--keys",
    "DATABASE_URL,OPENAI_API_KEY",
    "--test-project-only",
    "--apply",
    "--yes"
  ],
  "expectedSafety": [
    "refuses non-test projects",
    "never prints secret values",
    "requires explicit key allowlist",
    "requires --test-project-only --apply --yes for writes"
  ]
}
